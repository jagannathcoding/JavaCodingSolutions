class Solution {
    public int nearestExit(char[][] maze, int[] entrance) {
        
        int m=maze.length;
        int n=maze[0].length;
        
        int delrow[] = {-1, 0, +1, 0};
        int delcol[] = {0, 1, 0, -1}; 
        
        Queue<int[]>q=new LinkedList<>();
        q.add(new int[]{entrance[0], entrance[1]});

        //maze[entrance[0]][entrance[1]]='+';
        maze[entrance[0]][entrance[1]] = '+';

        int steps=0;

        while(!q.isEmpty())
        {
            int size=q.size();
            while(size-->0)
            {
                int curr[]=q.poll();
                int x=curr[0];
                int y=curr[1];
                if(!(x==entrance[0] && y==entrance[1]) && (x==0||x==m-1||y==0||y==n-1))
                return steps;

                for (int k = 0; k < 4; k++) {
                    int nx = x + delrow[k];
                    int ny = y + delcol[k];

                    if (nx >= 0 && nx < m && ny >= 0 && ny < n && maze[nx][ny] == '.') {
                        q.add(new int[]{nx, ny});
                        maze[nx][ny] = '+'; // mark visited
                    }
                }
            
            }
            steps++;
        }

        return -1;
    }
}
